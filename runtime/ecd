source api
addr=$1
value=$2
if [ -z $addr ]; then
    echo "No Parameters"
    exit
fi
source api

axi ECD_ADDR $1  

if [ -z $value ]; then
    axi ECD_START_RW 0
    while [ $(get ECD_RESP) -eq 0 ]; do
        sleep .1
    done
    resp=$(get ECD_RESP)
    test $resp -ne 1 && echo "ERROR: $resp"
    axi ECD_RDATA
    exit 
fi


axi ECD_WDATA $value 
axi ECD_START_RW 1
while [ $(get ECD_RESP) -eq 0 ]; do
    sleep .1
done
resp=$(get ECD_RESP)
test $resp -ne 1 && echo "ERROR: $resp"
